# Required to boot the frontend locally
VITE_API_BASE_URL=http://localhost:4000/api

# Optional wallet / Soroban config
VITE_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
VITE_RPC_URL=https://soroban-testnet.stellar.org

# Optional frontend fallback contract config
# The preferred source of truth is the backend contract_registry row.
VITE_PADALA_ESCROW_CONTRACT_ID=
VITE_USDC_CONTRACT_ID=

# Optional Supabase frontend auth config
# Needed only for legacy wallet-binding pages such as /bind-wallet.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_ANON_KEY=
VITE_DEV_AUTH_EMAIL=
VITE_DEV_AUTH_PASSWORD=
