# Backend runtime
NODE_ENV=development
APP_ENV=staging
PORT=4000

# Required for judge/demo workflow
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
ACTOR_SESSION_HMAC_SECRET=replace-with-a-random-long-string

# Optional storage config
# The backend will try to create this bucket automatically on first proof upload.
SUPABASE_STORAGE_BUCKET=delivery-evidence

# Optional AI config
# Use "auto" to enable Gemini only when GEMINI_API_KEY is present.
ORACLE_PROVIDER=auto
GEMINI_API_KEY=
ORACLE_CONFIDENCE_THRESHOLD=0.8

# Required only for legacy release-attestation / contract-verification flows
ORACLE_SECRET_KEY=
ORACLE_PUBLIC_KEY=
ATTESTATION_TTL_SECONDS=900
WALLET_CHALLENGE_TTL_SECONDS=300

# Optional cookie config
ACTOR_SESSION_COOKIE_NAME=padala_actor_session

# Legacy / fallback chain config
# Current workflow routes resolve contract metadata from the contract_registry table instead.
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
USDC_CONTRACT_ID=
PADALA_ESCROW_CONTRACT_ID=

# Optional testnet-only buyer setup helper
# When set, the backend can mint the active token to buyer wallets after they add the required trustline.
TOKEN_ADMIN_SECRET=
